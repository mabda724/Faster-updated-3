# ============================================================
# FASTER APP - ENVIRONMENT CONFIGURATION
# ============================================================
# SECURITY NOTICE:
# For production builds, pass keys via --dart-define instead:
#
#   flutter build apk --dart-define=SUPABASE_URL=... --dart-define=SUPABASE_ANON_KEY=...
#
# This prevents keys from appearing in plaintext in assets/.
# See lib/core/security/app_sec_config.dart for --dart-define handling.
# ============================================================

# Supabase Configuration (use --dart-define in production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Paymob Configuration (use --dart-define in production)
PAYMOB_PUBLIC_KEY=your_paymob_public_key_here
PAYMOB_SECRET_KEY=your_paymob_secret_key_here
PAYMOB_INTEGRATION_ID_CARD=your_integration_id_card_here
PAYMOB_INTEGRATION_ID_WALLET=your_integration_id_wallet_here

# Admin
ADMIN_EMAIL=admin@faster.com

# Server
PAYMENT_SERVER_URL=http://10.0.2.2:3001

# Environment
FLUTTER_ENV=development

# ============================================================
# SSL Pinning (--dart-define only - NEVER in .env):
#
#   flutter build apk --dart-define=SSL_PINNED_HOSTS="host1=FP1,FP2;host2=FP3"
#
# Format: host1=FP1_SHA256,FP2_SHA256;host2=FP3_SHA256
# ============================================================